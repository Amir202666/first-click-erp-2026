# ═══════════════════════════════════════════════════════════
# First Click ERP — بيئة التطوير المحلية (Laragon / XAMPP)
# انسخ إلى: backend\.env
# ═══════════════════════════════════════════════════════════

APP_NAME="First Click ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://first-click.test
# أو مع artisan serve:
# APP_URL=http://127.0.0.1:8000

FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=firstclick_local
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database

# أسعار الصرف — إن فشل SSL محلياً
# EXCHANGE_RATE_VERIFY_SSL=false

# ⚠️ محلياً: لا تستخدم Redis إلا إذا كان شغّالاً
CACHE_STORE=database
SESSION_DRIVER=database
QUEUE_CONNECTION=database

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173,first-click.test

# بيانات الدخول بعد: php artisan local:setup
# معرف الشركة: first-company
# admin@firstclickerp.com / FirstClick@2026
# firstclick-erp / FirstClickERP
