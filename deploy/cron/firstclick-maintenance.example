# First Click ERP — صيانة يومية
# cp إلى /etc/cron.d/firstclick-maintenance ثم chmod 644
# أنشئ /root/.my.cnf لنسخ DB (انظر docs/PERFORMANCE-AR.md)

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin

# Laravel scheduler
* * * * * www-data cd /var/www/erp/backend && php artisan schedule:run >> /dev/null 2>&1

# حذف سجلات Laravel الأقدم من 14 يوماً
15 2 * * * root find /var/www/erp/backend/storage/logs -name "*.log" -mtime +14 -delete

# نسخة احتياطية DB يومياً 03:00 (يتطلب /root/.my.cnf)
0 3 * * * root bash /var/www/erp/deploy/backup-daily.sh >> /var/www/backups/backup.log 2>&1
