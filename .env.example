# First Click ERP - Environment Example
# انسخ هذا الملف إلى .env في مجلد backend

APP_NAME="First Click ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Database - PostgreSQL
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=first_click_erp
DB_USERNAME=postgres
DB_PASSWORD=

# Multi-tenancy
TENANCY_DOMAIN=localhost
TENANCY_DATABASE_SUFFIX=_tenant

# Frontend URL (for CORS & Sanctum)
FRONTEND_URL=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:8000,::1
