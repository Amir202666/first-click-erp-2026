# Secrets
.env
.env.local
.env.*.local
backend/.env
backend/.env.*
!backend/.env.example
!backend/.env.local.example
frontend/.env
frontend/.env.*
!frontend/.env.example
!frontend/.env.local.example

# Backend dependencies & cache
backend/vendor/
backend/node_modules/
backend/public/hot
backend/public/storage
backend/storage/*.key
backend/bootstrap/cache/*.php
!backend/bootstrap/cache/.gitignore

# Frontend build
frontend/node_modules/
frontend/dist/

# IDE / OS
.vscode/
.idea/
*.log
.DS_Store
Thumbs.db

# Database export backups (local migration)
scripts/backups/*.sql
scripts/backups/*.sqlite
backend/db_export.sql
backend/storage/app/exports/*.sql
# Snapshot pushed with «رفع كل شيء» — not ignored:
!deploy/db_backup.sql

# Local test dumps
tmp-*.json
tmp-*.txt
